{
  "problem_class": "JobAssignmentProblem",
  "model_type": "Integer Program",
  "sense": "minimize",
  "sets": {
    "Workers": {
      "size": null,
      "index_symbol": "w",
      "source": "workers.csv",
      "column": "worker_id"
    },
    "Tasks": {
      "size": null,
      "index_symbol": "t",
      "source": "tasks.csv",
      "column": "task_id"
    }
  },
  "parameters": {
    "cost": {
      "domain": ["Workers", "Tasks"],
      "type": "float",
      "source": "costs.csv",
      "column": "cost",
      "index_columns": ["worker_id", "task_id"]
    }
  },
  "variables": {
    "assign": {
      "description": "1 if worker w is assigned to task t, 0 otherwise",
      "label": "assign",
      "domain": ["Workers", "Tasks"],
      "type": "binary",
      "lower_bound": 0,
      "upper_bound": 1,
      "upper_bound_set": null,
      "exclude_diagonal": false
    }
  },
  "objective": {
    "sense": "minimize",
    "expression": {
      "operation": "indexed_sum",
      "over": ["Workers", "Tasks"],
      "body": {
        "operation": "multiply",
        "left": {"type": "parameter", "name": "cost", "indices": ["w", "t"]},
        "right": {"type": "variable", "name": "assign", "indices": ["w", "t"]}
      }
    }
  },
  "constraints": {
    "task_assigned": {
      "domain": ["Tasks"],
      "expression": {
        "operation": "indexed_sum",
        "over": ["Workers"],
        "body": {"type": "variable", "name": "assign", "indices": ["w", "t"]}
      },
      "sense": "=",
      "rhs": {"type": "constant", "value": 1}
    },
    "worker_limit": {
      "domain": ["Workers"],
      "expression": {
        "operation": "indexed_sum",
        "over": ["Tasks"],
        "body": {"type": "variable", "name": "assign", "indices": ["w", "t"]}
      },
      "sense": "<=",
      "rhs": {"type": "constant", "value": 1}
    }
  }
}
